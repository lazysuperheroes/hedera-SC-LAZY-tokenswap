####
# Network: MAIN or TEST
ENVIRONMENT=TEST
ACCOUNT_ID=
PRIVATE_KEY=
####

# UnifiedTokenSwap (recommended)
UNIFIED_TOKEN_SWAP_CONTRACT_ID=
TOKEN_GRAVEYARD_CONTRACT_ID=

# Legacy contracts (NoFallbackTokenSwap / FallbackTokenSwap)
TOKEN_SWAP_CONTRACT_ID=
FALLBACK_TOKEN_SWAP_CONTRACT_ID=
LAZY_TOKEN_ID=0.0.2185
LAZY_SCT_CONTRACT_ID=0.0.2181
LAZY_GAS_STATION_CONTRACT_ID=
TOKEN_TREASURY=0.0.2233
SWAP_TOKEN=

####
# Source verification (Sourcify via @lazysuperheroes/hedera-verify)
####
# Set to true to auto-verify a contract on Sourcify right after deployment.
# Verification is read-only (mirror node + Sourcify) — no key or gas is used.
# Leave unset/false to deploy without publishing source.
VERIFY_ON_DEPLOY=false
# Verify deployed contracts any time with: npm run verify
# (reads the deployed *_CONTRACT_ID vars above against verify.config.cjs)
